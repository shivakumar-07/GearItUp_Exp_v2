# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# ─── JWT Secrets ────────────────────────────────────────────────────────────────
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# ─── Firebase Admin SDK (Phone OTP + Google Auth) ───────────────────────────────
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Email (Resend) ─────────────────────────────────────────────────────────────
# Sign up at https://resend.com — required for OTP emails, password reset, welcome emails
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
RESEND_SENDER_EMAIL="noreply@yourdomain.com"
RESEND_SENDER_NAME="redpiston"

# ─── OTP / SMS (MSG91) — fallback non-Firebase phone OTP ────────────────────────
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-otp-template-id"

# ─── WhatsApp (WATI) ────────────────────────────────────────────────────────────
WATI_API_URL="https://live-server-XXXX.wati.io/api/v1"
WATI_ACCESS_TOKEN="your-wati-access-token"

# ─── Razorpay ───────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID="rzp_test_XXXXXXXX"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# ─── Cloudflare R2 (PDF invoice storage) ────────────────────────────────────────
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="autospace-docs"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# ─── Server ─────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Frontend URL used in password reset email links
RESET_PASSWORD_URL="http://localhost:5173/reset-password"
FRONTEND_APP_URL="http://localhost:5173"
# Comma-separated list of allowed CORS origins (supports wildcard subdomains)
FRONTEND_URL="http://localhost:5173,http://localhost:5174,http://localhost:5175,https://autospace-mvp.vercel.app,https://*.vercel.app"
