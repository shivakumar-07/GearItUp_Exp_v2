# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# JWT Secrets
JWT_SECRET="your-super-secret-jwt-key-change-this"
JWT_REFRESH_SECRET="your-refresh-secret-change-this"
JWT_EXPIRES_IN="8h"
JWT_REFRESH_EXPIRES_IN="30d"

# OTP Service (MSG91)
MSG91_AUTH_KEY="your-msg91-auth-key"
MSG91_TEMPLATE_ID="your-otp-template-id"

# WhatsApp (WATI)
WATI_API_URL="https://live-server-XXXX.wati.io/api/v1"
WATI_ACCESS_TOKEN="your-wati-access-token"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_XXXXXXXX"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Cloudflare R2 (for PDF storage)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET_NAME="autospace-docs"
R2_PUBLIC_URL="https://your-r2-public-url.r2.dev"

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
